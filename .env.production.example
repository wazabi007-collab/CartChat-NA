# ─── OshiCart Production Environment Variables ─────
# Copy this to .env.production and fill in real values
# NEVER commit .env.production to git

# ─── Database ──────────────────────────────────────
# Generate a strong password: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── JWT ───────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_here

# ─── Supabase Keys ────────────────────────────────
# Generate these using your JWT_SECRET at:
# https://supabase.com/docs/guides/self-hosting#api-keys
# Or use: node -e "const jwt=require('jsonwebtoken'); console.log(jwt.sign({role:'anon',iss:'supabase',iat:Math.floor(Date.now()/1000),exp:Math.floor(Date.now()/1000)+315360000}, 'YOUR_JWT_SECRET'))"
ANON_KEY=CHANGE_ME
SERVICE_ROLE_KEY=CHANGE_ME

# ─── Twilio (SMS OTP) ─────────────────────────────
# Sign up at https://www.twilio.com
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_MESSAGE_SERVICE_SID=CHANGE_ME
