  Answered by
  [icyJoseph](https://github.com/icyJoseph)[on Jan 13, 2023Jan 13, 2023](https://github.com/vercel/next.js/discussions/44836#discussioncomment-4674680)
  
  You could define a data getter at page level, and then from within \_app collect the page data, if any, and merge that with some baseline/defaults.
  
  ```
  import type { AppProps } from "next/app";
  
  type AnyObject = Record<string, unknown>;
  
  type Data = {'@content': string; '@type': string; name: string; pid: number}
  
  export type MyPage<P = AnyObject, IP = AnyObject> = NextPage<P, IP> & {
      getJSONStructuredData?: (pageProps: P) => Array<Data>;
  };
  
  type MyAppProps = AppProps & {
      Component: MyPage;
  }
  
  const MyApp = ({Component, pageProps, initialState}: MyAppProps) =>  {
      return (
          <>
                  <InjectSEO pageOwnData={Component?.getJSONStructuredData?.(pageProps)} />
        …
  ```
  
